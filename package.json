{
  "name": "transpose-react",
  "version": "6.4.0",
  "private": true,
  "description": "Transpose ▲▼ pitch ▹ speed ▹ loop — Chrome Extension (React port)",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "clean": "node -e \"const{rmSync,existsSync}=require('fs');const p='./dist';if(existsSync(p))rmSync(p,{recursive:true,force:true});console.log('Cleaned dist/');\"",
    "package": "cd dist && bestzip ../transpose-react-v6.4.0.zip *"
  },
  "keywords": [
    "chrome-extension",
    "pitch-shifter",
    "audio",
    "transpose",
    "speed-control",
    "react"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vite-plugin-static-copy": "^1.0.6"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
